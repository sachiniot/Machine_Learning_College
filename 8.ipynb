   "source": [
    "import pandas as pd\n",
    "from sklearn.cluster import KMeans\n",
    "\n",
    "data = {\n",
    "    \"Age\":[22,25,30,40,42,45],\n",
    "    \"Spending\":[200,220,250,600,620,650]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "kmeans = KMeans(n_clusters=2)\n",
    "\n",
    "kmeans.fit(df)\n",
    "\n",
    "clusters = kmeans.predict(df)\n",
    "\n",
    "print(clusters)"
   ]
